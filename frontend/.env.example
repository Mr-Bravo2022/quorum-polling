# Class MQTT broker — TLS-WebSocket on 443, path /mqtt (see realtime-web cheatsheet).
VITE_MQTT_URL=wss://mqtt.uvucs.org:443/mqtt
# Your broker credentials (issued for the course, e.g. via Canvas).
# Note: these are bundled into the browser build — fine for the shared class broker.
VITE_MQTT_USER=
VITE_MQTT_PASS=

VITE_MQTT_TOPIC_PREFIX=cs3660/polling
